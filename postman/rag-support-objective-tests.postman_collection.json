{
  "info": {
    "name": "RAG Support — Objective-Based Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Objective-focused Postman scenarios for Chapter 4 evidence (RAG pipeline, explainability, fallback, analytics/reporting, and cross-cutting checks)."
  },
  "item": [
    {
      "name": "00 Cross-Cutting / Auth & Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.test('Health payload has status ok', function () { pm.expect(json.status).to.eql('ok'); });"
              ] }
            }
          ]
        },
        {
          "name": "Register Customer (dynamic email)",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const email = `customer_${Date.now()}@example.com`;",
                "pm.environment.set('customerEmail', email);"
              ] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                "const json = pm.response.json();",
                "pm.environment.set('customerId', json.id);",
                "pm.test('Role is customer', function () { pm.expect(json.role).to.eql('customer'); });"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{customerName}}\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.environment.set('customerToken', json.access_token);",
                "pm.test('Token exists', function () { pm.expect(json.access_token).to.be.a('string').and.not.empty; });"
              ] }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.environment.set('adminToken', json.access_token);",
                "pm.test('Admin role', function () { pm.expect(json.user.role).to.eql('admin'); });"
              ] }
            }
          ]
        },
        {
          "name": "Login Agent",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{agentEmail}}\",\n  \"password\": \"{{agentPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.environment.set('agentToken', json.access_token);",
                "pm.test('Agent role', function () { pm.expect(json.user.role).to.eql('agent'); });"
              ] }
            }
          ]
        },
        {
          "name": "RBAC Check: Customer -> Admin Analytics (should fail)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{customerToken}}"}],
            "url": { "raw": "{{baseUrl}}/analytics/overview", "host": ["{{baseUrl}}"], "path": ["analytics","overview"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('RBAC blocks customer (403)', function () { pm.response.to.have.status(403); });"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "01 Objective 1 — RAG Pipeline",
      "item": [
        {
          "name": "Upload PDF Document (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/documents/", "host": ["{{baseUrl}}"], "path": ["documents",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Upload status 201', function () { pm.response.to.have.status(201); });",
                "const json = pm.response.json();",
                "pm.environment.set('documentId', json.id);",
                "pm.test('Document id saved', function () { pm.expect(json.id).to.be.a('number'); });"
              ] }
            }
          ]
        },
        {
          "name": "List Documents (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/documents/?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["documents",""] , "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const json = pm.response.json();",
                "pm.test('Has pagination fields', function () { pm.expect(json).to.have.property('items'); pm.expect(json).to.have.property('total'); });"
              ] }
            }
          ]
        },
        {
          "name": "Create Conversation (customer)",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Authorization","value":"Bearer {{customerToken}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"title\": null\n}"},
            "url": { "raw": "{{baseUrl}}/chat/", "host": ["{{baseUrl}}"], "path": ["chat",""] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
            "const json = pm.response.json();",
            "pm.environment.set('conversationId', json.id);"
          ]}}]
        },
        {
          "name": "Send Query (customer)",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Authorization","value":"Bearer {{customerToken}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"content\": \"How do I enable 2FA on my account?\"\n}"},
            "url": { "raw": "{{baseUrl}}/chat/{{conversationId}}/message", "host": ["{{baseUrl}}"], "path": ["chat","{{conversationId}}","message"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Contains assistant message', function () { pm.expect(json.message).to.have.property('content'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "02 Objective 2 — Explainability",
      "item": [
        {
          "name": "Send Query and Check Sources (customer)",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Authorization","value":"Bearer {{customerToken}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"content\": \"What is your return policy for smart devices?\"\n}"},
            "url": { "raw": "{{baseUrl}}/chat/{{conversationId}}/message", "host": ["{{baseUrl}}"], "path": ["chat","{{conversationId}}","message"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Explainability fields exist', function () {",
            "  pm.expect(json).to.have.property('sources');",
            "  pm.expect(json).to.have.property('highlights');",
            "});"
          ]}}]
        },
        {
          "name": "Document Preview by documentId",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{customerToken}}"}],
            "url": { "raw": "{{baseUrl}}/documents/{{documentId}}/preview?limit=5", "host": ["{{baseUrl}}"], "path": ["documents","{{documentId}}","preview"], "query": [{"key":"limit","value":"5"}] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Preview has chunks', function () { pm.expect(json).to.have.property('chunks'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "03 Objective 3 — Human Fallback / Escalation",
      "item": [
        {
          "name": "Manual Escalation (customer)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{customerToken}}"}],
            "url": { "raw": "{{baseUrl}}/chat/{{conversationId}}/escalate", "host": ["{{baseUrl}}"], "path": ["chat","{{conversationId}}","escalate"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.environment.set('ticketId', json.ticket.id);",
            "pm.test('Ticket created', function () { pm.expect(json.ticket.id).to.be.a('number'); });"
          ]}}]
        },
        {
          "name": "List Tickets (agent)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{agentToken}}"}],
            "url": { "raw": "{{baseUrl}}/tickets/?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["tickets",""] , "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Returns tickets array', function () { pm.expect(json.items).to.be.an('array'); });"
          ]}}]
        },
        {
          "name": "Update Ticket Status -> in_progress (agent)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key":"Authorization","value":"Bearer {{agentToken}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"status\": \"in_progress\"\n}"},
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["tickets","{{ticketId}}"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Status changed', function () { pm.expect(json.status).to.eql('in_progress'); });"
          ]}}]
        },
        {
          "name": "Agent Respond to Ticket",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Authorization","value":"Bearer {{agentToken}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"content\": \"I have taken over your case and will assist you shortly.\"\n}"},
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/respond", "host": ["{{baseUrl}}"], "path": ["tickets","{{ticketId}}","respond"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ]}}]
        }
      ]
    },
    {
      "name": "04 Objective 4 — Analytics & Reporting",
      "item": [
        {
          "name": "Analytics Overview (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/analytics/overview", "host": ["{{baseUrl}}"], "path": ["analytics","overview"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('Overview has total_queries', function(){ pm.expect(json).to.have.property('total_queries'); });"
          ]}}]
        },
        {
          "name": "Query Trends (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/analytics/query-trends?interval=day", "host": ["{{baseUrl}}"], "path": ["analytics","query-trends"], "query": [{"key":"interval","value":"day"}] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "Escalation Trend (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/analytics/escalation-trend?interval=day", "host": ["{{baseUrl}}"], "path": ["analytics","escalation-trend"], "query": [{"key":"interval","value":"day"}] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "Download Analytics Summary CSV (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/reports/analytics-summary", "host": ["{{baseUrl}}"], "path": ["reports","analytics-summary"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "pm.test('CSV content-type', function(){ pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv'); });"
          ]}}]
        },
        {
          "name": "Download Analytics PDF (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": { "raw": "{{baseUrl}}/reports/analytics", "host": ["{{baseUrl}}"], "path": ["reports","analytics"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "pm.test('PDF content-type', function(){ pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "99 Cleanup (optional)",
      "item": [
        {
          "name": "Delete Conversation (customer)",
          "request": {
            "method": "DELETE",
            "header": [{"key":"Authorization","value":"Bearer {{customerToken}}"}],
            "url": { "raw": "{{baseUrl}}/chat/{{conversationId}}", "host": ["{{baseUrl}}"], "path": ["chat","{{conversationId}}"] }
          },
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Status 204', function () { pm.response.to.have.status(204); });"
          ]}}]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api" }
  ]
}
